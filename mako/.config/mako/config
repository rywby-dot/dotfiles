font=sans-serif 12
# Расположение в правом верхнем углу
anchor=top-right

# Исчезновение через 4 секунды (4000 миллисекунд)
default-timeout=5000

# Цвет фона #14161b (ff в конце означает полную непрозрачность)
background-color=#14161bff

# Цвет текста (белый, для контраста)
text-color=#ffffffff

# Толщина обводки 2 пикселя
border-size=2

# Цвет обводки #dc6400 (ff - полная непрозрачность)
border-color=#36aca3ff

# Отключаем скругления углов, чтобы форма была строго прямоугольной
border-radius=0

# Внутренние и внешние отступы
margin=10
padding=10

# Настройки группировки/отображения (чтобы уведомления не сливались)
max-visible=5
sort=-time
